# Server Configuration
PORT=8085
BASE_URL=http://localhost:8085

# PostgreSQL Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=shareit
POSTGRES_PASSWORD=changeme_secure_password_here
POSTGRES_DB=shareit

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Storage Configuration
DATA_DIR=/data

# Proxy Configuration
# Set to true if running behind Cloudflare or similar reverse proxy
BEHIND_CLOUDFLARE=false

# File Limits
# Maximum file size in bytes (default: 750MB = 786432000)
MAX_FILE_SIZE=786432000

# Report Configuration
# Number of reports before automatic deletion (default: 3)
AUTO_DELETE_REPORT_COUNT=3

# Discord Webhook (optional)
# Leave empty to disable Discord notifications
DISCORD_WEBHOOK_URL=

# Gin Mode (debug or release)
GIN_MODE=debug

# CNS Auth integration (optional — omit to run without auth tiers)
CNS_AUTH_URL=https://auth.cns-studios.com
CNS_AUTH_CLIENT_ID=
CNS_AUTH_DESKTOP_CLIENT_ID=dropzone
CNS_AUTH_SERVICE_KEY=
# Max file size for authenticated users (default 1.5 GB)
AUTH_MAX_FILE_SIZE=1610612736

# Migrations directory
MIGRATIONS_DIR=db/migrations