# Server Configuration
PORT=8080
BASE_URL=http://localhost:8080

# PostgreSQL Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=shareit
POSTGRES_PASSWORD=changeme_secure_password_here
POSTGRES_DB=shareit

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Storage Configuration
DATA_DIR=/data

# Proxy Configuration
# Set to true if running behind Cloudflare or similar reverse proxy
BEHIND_CLOUDFLARE=false

# File Limits
# Maximum file size in bytes (default: 750MB = 786432000)
MAX_FILE_SIZE=786432000

# Report Configuration
# Number of reports before automatic deletion (default: 3)
AUTO_DELETE_REPORT_COUNT=3

# Discord Webhook (optional)
# Leave empty to disable Discord notifications
DISCORD_WEBHOOK_URL=

# Gin Mode (debug or release)
GIN_MODE=debug